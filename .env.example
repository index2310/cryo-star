# Unhedged.gg AI Bot Configuration

# ── LLM Provider ──
# Options: groq (free!), deepseek, openai, gemini, local (ollama)
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your-groq-key-here

# Get free Groq key: https://console.groq.com/keys
# Get DeepSeek key: https://platform.deepseek.com/api_keys
# Get Gemini key:   https://aistudio.google.com/apikey

# ── Unhedged.gg ──
UNHEDGED_API_KEY=your-api-key-here

# ── Risk Management ──
MAX_BET_CC=5
MAX_BET_PERCENT=5
MIN_EDGE_PERCENT=10
MIN_TIME_LEFT_MINUTES=5
MAX_LOSING_STREAK=3

# ── Bot Mode ──
# "signal" = recommendations only | "auto" = auto-bet
BOT_MODE=auto

# ── Market Filter ──
MARKET_CATEGORIES=CRYPTO

# ── Other ──
PRICE_API=coingecko
DASHBOARD_PORT=3000
LOG_LEVEL=info
